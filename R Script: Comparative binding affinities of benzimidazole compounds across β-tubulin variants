# --------------------- 3. GNINA 28 Å barplot ----------------------

gnina28_plot <- ggplot(docking, aes(x = Mutation, y = GNINA28, fill = Ligand)) +
  geom_col(position = position_dodge(width = 0.8), width = 0.75) +
  geom_text(
    aes(label = sprintf("%.2f", GNINA28)),
    position = position_dodge(width = 0.8),
    vjust = 1.5,
    size = 3.5
  ) +
  scale_fill_manual(values = ligand_palette) +
  scale_y_continuous(limits = c(-7.5, 0)) +
  theme_bw(base_size = 14) +
  labs(
    x = "β-tubulin variant",
    y = "Binding affinity (kcal/mol)",
    fill = "Ligand",
    title = "GNINA 28 Å docking scores"
  )

